.page { padding: 24rpx; background: #FFFFFF; min-height: 100vh; }
.page-title { font-size: 36rpx; font-weight: bold; color: #2E8B57; display: block; margin-bottom: 8rpx; }
.page-sub { font-size: 24rpx; color: #888; display: block; margin-bottom: 24rpx; }
.loading, .empty { text-align: center; padding: 80rpx; color: #999; }
.chart-container { background: #FAFAFA; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; display: flex; align-items: flex-end; justify-content: space-around; height: 320rpx; border: 1rpx solid #E0E0E0; }
.bar-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
.bar-wrap { flex: 1; display: flex; align-items: flex-end; justify-content: center; }
.bar { width: 40rpx; background: #3CB371; border-radius: 6rpx 6rpx 0 0; min-height: 8rpx; transition: height 0.3s; }
.bar.high-risk { background: #F44336; }
.bar-label { font-size: 20rpx; color: #888; margin-top: 8rpx; }
.bar-val { font-size: 22rpx; color: #333; }
.bar-val.red { color: #F44336; font-weight: bold; }
.detail-list { background: #FAFAFA; border-radius: 16rpx; overflow: hidden; border: 1rpx solid #E0E0E0; }
.detail-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.detail-item.high-risk { background: #fff8f8; }
.detail-label { font-size: 28rpx; color: #333; }
.detail-right { display: flex; align-items: center; gap: 16rpx; }
.detail-prob { font-size: 30rpx; font-weight: bold; color: #333; }
.detail-prob.red { color: #F44336; }
.risk-badge { background: #F44336; color: #fff; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; }
