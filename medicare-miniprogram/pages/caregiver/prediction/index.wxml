<view class="page">
  <text class="page-title">依从性预测</text>
  <text class="page-sub">未来3天各时段漏服概率（红色为高风险 &gt; 70%）</text>

  <view wx:if="{{loading}}" class="loading"><text>预测数据加载中...</text></view>

  <view wx:elif="{{slots.length === 0}}" class="empty">
    <text>暂无预测数据（需要至少14天服药记录）</text>
  </view>

  <block wx:else>
    <!-- 柱状图（原生模拟） -->
    <view class="chart-container">
      <view wx:for="{{slots}}" wx:key="index" class="bar-item">
        <view class="bar-wrap">
          <view
            class="bar {{item.is_high_risk ? 'high-risk' : ''}}"
            style="height: {{item.bar_height}}rpx"
          ></view>
        </view>
        <text class="bar-label">第{{item.day_offset}}天{{item.slot_cn}}</text>
        <text class="bar-val {{item.is_high_risk ? 'red' : ''}}">{{item.prob_pct0}}%</text>
      </view>
    </view>

    <!-- 详细列表 -->
    <view class="detail-list">
      <view wx:for="{{slots}}" wx:key="index" class="detail-item {{item.is_high_risk ? 'high-risk' : ''}}">
        <text class="detail-label">第{{item.day_offset}}天 {{item.slot_cn_full}}</text>
        <view class="detail-right">
          <text class="detail-prob {{item.is_high_risk ? 'red' : ''}}">{{item.prob_pct1}}%</text>
          <text wx:if="{{item.is_high_risk}}" class="risk-badge">高风险</text>
        </view>
      </view>
    </view>
  </block>
</view>
