<view class="page">
  <view class="hero">
    <text class="hero-icon">📋</text>
    <text class="hero-title">就诊报告</text>
    <text class="hero-sub">一键生成包含完整用药记录的PDF报告，方便就医时提供给医生</text>
  </view>

  <view class="content-list">
    <view class="content-item"><text class="check">✓</text><text>患者基本信息与诊断</text></view>
    <view class="content-item"><text class="check">✓</text><text>28天用药总览</text></view>
    <view class="content-item"><text class="check">✓</text><text>14天每日服药明细表</text></view>
    <view class="content-item"><text class="check">✓</text><text>长期服药史列表</text></view>
    <view class="content-item"><text class="check">✓</text><text>过敏药物清单</text></view>
    <view class="content-item"><text class="check">✓</text><text>依从性预测摘要</text></view>
    <view class="content-item"><text class="check">✓</text><text>关联规则洞察（Top 5）</text></view>
    <view class="content-item"><text class="check">✓</text><text>医生备注留白</text></view>
  </view>

  <button
    class="download-btn"
    loading="{{generating}}"
    bindtap="onDownloadReport"
  >
    生成并下载 PDF 报告
  </button>
</view>
