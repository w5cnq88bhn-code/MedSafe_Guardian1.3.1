.page { padding: 24rpx; background: #FFFFFF; min-height: 100vh; }
.page-title { font-size: 36rpx; font-weight: bold; color: #2E8B57; display: block; margin-bottom: 8rpx; }
.page-sub { font-size: 24rpx; color: #888; display: block; margin-bottom: 24rpx; }
.loading, .empty { text-align: center; padding: 80rpx; color: #999; }
.rule-card { background: #FAFAFA; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); border: 1rpx solid #E0E0E0; }
.rule-desc { font-size: 28rpx; color: #222; line-height: 1.6; display: block; margin-bottom: 20rpx; }
.rule-metrics { display: flex; justify-content: space-around; padding: 16rpx 0; border-top: 1rpx solid #f0f0f0; border-bottom: 1rpx solid #f0f0f0; margin-bottom: 16rpx; }
.metric { text-align: center; }
.metric-val { font-size: 36rpx; font-weight: bold; color: #2E8B57; display: block; }
.metric-label { font-size: 22rpx; color: #888; }
.suggestion { display: flex; align-items: flex-start; gap: 8rpx; background: #F0F7F0; border-radius: 10rpx; padding: 16rpx; }
.suggestion-icon { font-size: 28rpx; }
.suggestion-text { font-size: 24rpx; color: #2E8B57; flex: 1; line-height: 1.5; }
