<view class="page">
  <text class="page-title">关联规则洞察</text>
  <text class="page-sub">基于历史服药记录挖掘的用药关联规律</text>

  <view wx:if="{{loading}}" class="loading"><text>加载中...</text></view>

  <view wx:elif="{{rules.length === 0}}" class="empty">
    <text>暂无关联规则（需要至少30天服药记录）</text>
  </view>

  <view wx:else>
    <view wx:for="{{rules}}" wx:key="id" class="rule-card">
      <view class="rule-header">
        <text class="rule-desc">{{item.rule_description}}</text>
      </view>
      <view class="rule-metrics">
        <view class="metric">
          <text class="metric-val">{{item.confidence_pct}}%</text>
          <text class="metric-label">置信度</text>
        </view>
        <view class="metric">
          <text class="metric-val">{{item.support_pct}}%</text>
          <text class="metric-label">支持度</text>
        </view>
        <view class="metric">
          <text class="metric-val">{{item.lift_str}}</text>
          <text class="metric-label">提升度</text>
        </view>
      </view>
      <view class="suggestion">
        <text class="suggestion-icon">💡</text>
        <text class="suggestion-text">{{item.suggestion}}</text>
      </view>
    </view>
  </view>
</view>
