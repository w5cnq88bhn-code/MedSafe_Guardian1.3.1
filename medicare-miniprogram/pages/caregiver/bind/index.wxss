/* 页面容器 */
.bind-container {
  padding: 60rpx 40rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* 顶部图标区 */
.header-icon {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}
.hero-emoji {
  font-size: 120rpx;
  display: block;
}

/* 标题区 */
.title-section {
  text-align: center;
  margin-bottom: 60rpx;
}
.main-title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #1a5f7a;
  margin-bottom: 20rpx;
}
.sub-title {
  display: block;
  font-size: 32rpx;
  color: #666;
  line-height: 1.6;
  padding: 0 20rpx;
}

/* 输入区 */
.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
.label-icon {
  margin-right: 16rpx;
  font-size: 36rpx;
}
.phone-input {
  height: 96rpx;
  font-size: 36rpx;
  border-bottom: 2rpx solid #e8e8e8;
  width: 100%;
  box-sizing: border-box;
}
.placeholder-style {
  font-size: 32rpx;
  color: #999;
}

/* 绑定按钮 */
.bind-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #1a5f7a;
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-icon {
  margin-right: 12rpx;
  font-size: 40rpx;
  font-weight: 300;
}
