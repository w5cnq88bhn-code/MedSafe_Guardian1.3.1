<view class="page">
  <text class="title">完善个人信息</text>
  <text class="subtitle">请填写以下信息以完成注册</text>

  <view class="form">
    <view class="form-item">
      <text class="label">姓名 *</text>
      <input class="input" placeholder="请输入真实姓名" data-field="name" bindinput="onInput" value="{{form.name}}" />
    </view>
    <view class="form-item">
      <text class="label">手机号 *</text>
      <input class="input" type="number" placeholder="请输入手机号" data-field="phone" bindinput="onInput" value="{{form.phone}}" maxlength="11" />
    </view>
    <view class="form-item">
      <text class="label">出生年份 *</text>
      <input class="input" type="number" placeholder="如：1950" data-field="birth_year" bindinput="onInput" value="{{form.birth_year}}" maxlength="4" />
    </view>
    <view class="form-item">
      <text class="label">诊断病种</text>
      <input class="input" placeholder="如：高血压、糖尿病（选填）" data-field="diagnosis_disease" bindinput="onInput" value="{{form.diagnosis_disease}}" />
    </view>
  </view>

  <button class="submit-btn" loading="{{submitting}}" bindtap="onSubmit">完成注册</button>
</view>
