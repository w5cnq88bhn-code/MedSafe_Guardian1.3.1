.page { padding: 48rpx 32rpx; background: #FFFFFF; min-height: 100vh; }
.title { font-size: 44rpx; font-weight: bold; color: #2E8B57; display: block; margin-bottom: 12rpx; }
.subtitle { font-size: 28rpx; color: #888; display: block; margin-bottom: 48rpx; }
.form { background: #FAFAFA; border-radius: 16rpx; padding: 8rpx 24rpx; margin-bottom: 40rpx; border: 1rpx solid #E0E0E0; }
.form-item { padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.form-item:last-child { border-bottom: none; }
.label { font-size: 28rpx; color: #555; display: block; margin-bottom: 12rpx; }
.input { font-size: 30rpx; color: #222; border: 2rpx solid #eee; border-radius: 10rpx; padding: 16rpx; width: 100%; box-sizing: border-box; }
.submit-btn { background: linear-gradient(135deg, #FFB347 0%, #FFA726 100%); color: #5D4037; border-radius: 16rpx; font-size: 32rpx; height: 96rpx; line-height: 96rpx; box-shadow: 0 4rpx 12rpx rgba(255,179,71,0.3); }
