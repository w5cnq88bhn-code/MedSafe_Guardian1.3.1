<view class="page">
  <view class="profile-card">
    <view class="avatar">
      <text class="avatar-icon">👤</text>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{userInfo.name || '用户'}}</text>
      <text class="profile-phone">{{userInfo.phone || ''}}</text>
    </view>
  </view>

  <view class="menu-list">
    <navigator url="/pages/patient/allergy/index" class="menu-item">
      <text class="menu-icon">⚠️</text>
      <text class="menu-label">过敏信息</text>
      <text class="menu-arrow">›</text>
    </navigator>
    <navigator url="/pages/patient/add-drug/index" class="menu-item">
      <text class="menu-icon">💊</text>
      <text class="menu-label">添加药物</text>
      <text class="menu-arrow">›</text>
    </navigator>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>
