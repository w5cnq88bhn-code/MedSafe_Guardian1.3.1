<view class="page">
  <view class="header">
    <text class="header-title">今日用药</text>
    <button class="add-btn" bindtap="onAddDrug">+ 添加药物</button>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{groups.length === 0}}" class="empty">
    <text>今日暂无用药计划</text>
  </view>

  <block wx:else>
    <!-- 今日用药列表 -->
    <view wx:for="{{groups}}" wx:key="slot" class="group">
      <view class="group-header">
        <view class="section-title">
          <view class="slot-icon-wrap slot-{{item.slot}}">
            <text class="slot-icon">{{item.slotIcon}}</text>
          </view>
          <text class="slot-label">{{item.slotCn}}间用药</text>
        </view>
        <text class="group-time">{{item.drugs[0].time_point}}</text>
      </view>

      <view wx:for="{{item.drugs}}" wx:for-item="drug" wx:key="schedule_id" class="drug-card {{drug.status}}">
        <view class="drug-icon-wrap" style="background:{{drug.iconBg}}">
          <text class="drug-icon">{{drug.icon}}</text>
        </view>
        <view class="drug-info">
          <text class="drug-name">{{drug.drug_name}}</text>
          <text class="drug-brand">{{drug.brand_name}}</text>
          <text class="drug-dose">{{drug.dosage}}{{drug.dosage_unit}}</text>
        </view>
        <button
          class="take-btn {{drug.status}}"
          data-schedule-id="{{drug.schedule_id}}"
          data-status="{{drug.status}}"
          data-log-id="{{drug.log_id}}"
          bindtap="onTake"
          disabled="{{drug.status === 'missed'}}"
        >
          {{drug.status === 'taken' ? '已服 ✓' : drug.status === 'missed' ? '已漏服' : '标记已服'}}
        </button>
      </view>
    </view>

    <!-- 饮食小贴士卡片 -->
    <view wx:if="{{foodTips.length > 0}}" class="tips-card">
      <!-- 卡片标题栏（可折叠） -->
      <view class="tips-header" bindtap="onToggleTips">
        <view class="tips-title-row">
          <text class="tips-icon">🥗</text>
          <text class="tips-title">今日饮食小贴士</text>
          <text class="tips-count">{{foodTips.length}}条提醒</text>
        </view>
        <text class="tips-toggle">{{tipsExpanded ? '收起 ∧' : '展开 ∨'}}</text>
      </view>

      <!-- 贴士列表 -->
      <block wx:if="{{tipsExpanded}}">
        <view
          wx:for="{{foodTips}}"
          wx:key="drug_name"
          class="tip-item"
          style="border-left-color:{{item.severityColor}};background:{{item.severityBg}}"
        >
          <!-- 贴士头部：药物名 + 严重程度 + 展开按钮 -->
          <view
            class="tip-item-header"
            data-index="{{index}}"
            bindtap="onToggleTipDetail"
          >
            <view class="tip-drug-row">
              <text class="tip-severity-icon">{{item.severityIcon}}</text>
              <text class="tip-drug-name">{{item.drug_name}}</text>
              <view class="tip-badge" style="background:{{item.severityColor}}">
                <text class="tip-badge-text">{{item.severityLabel}}</text>
              </view>
            </view>
            <text class="tip-expand-btn">{{item.expanded ? '▲' : '▼'}}</text>
          </view>

          <!-- 服药时机提示（始终显示，最重要） -->
          <view wx:if="{{item.timing_tips.length > 0}}" class="tip-timing">
            <view wx:for="{{item.timing_tips}}" wx:for-item="tip" wx:key="*this" class="tip-timing-row">
              <text class="tip-timing-dot">⏰</text>
              <text class="tip-timing-text">{{tip}}</text>
            </view>
          </view>

          <!-- 展开后显示详情 -->
          <block wx:if="{{item.expanded}}">
            <!-- 禁忌食物 -->
            <view wx:if="{{item.avoid_foods.length > 0}}" class="tip-section">
              <text class="tip-section-title">🚫 避免食用</text>
              <view class="tip-tags">
                <text
                  wx:for="{{item.avoid_foods}}"
                  wx:for-item="food"
                  wx:key="*this"
                  class="tip-tag tip-tag-avoid"
                >{{food}}</text>
              </view>
            </view>

            <!-- 注意食物 -->
            <view wx:if="{{item.caution_foods.length > 0}}" class="tip-section">
              <text class="tip-section-title">⚡ 注意控量</text>
              <view class="tip-tags">
                <text
                  wx:for="{{item.caution_foods}}"
                  wx:for-item="food"
                  wx:key="*this"
                  class="tip-tag tip-tag-caution"
                >{{food}}</text>
              </view>
            </view>

            <!-- 原因说明 -->
            <view wx:if="{{item.reason}}" class="tip-reason">
              <text class="tip-reason-text">{{item.reason}}</text>
            </view>
          </block>
        </view>
      </block>
    </view>
  </block>
</view>
