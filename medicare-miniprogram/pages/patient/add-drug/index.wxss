.page { padding: 24rpx; background: #FFFFFF; min-height: 100vh; }
.section { background: #FAFAFA; border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; border: 1rpx solid #E0E0E0; }
.section-title { font-size: 32rpx; font-weight: bold; color: #2E8B57; display: block; margin-bottom: 20rpx; }
.search-row { display: flex; gap: 16rpx; }
.search-input { flex: 1; border: 2rpx solid #ddd; border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; }
.search-btn { background: linear-gradient(135deg, #FFB347 0%, #FFA726 100%); color: #5D4037; border-radius: 12rpx; font-size: 28rpx; padding: 0 28rpx; box-shadow: 0 4rpx 12rpx rgba(255,179,71,0.3); }
.search-results { margin-top: 16rpx; border: 2rpx solid #eee; border-radius: 12rpx; }
.result-item { padding: 20rpx; border-bottom: 1rpx solid #f0f0f0; }
.result-name { font-size: 30rpx; font-weight: bold; display: block; }
.result-brand { font-size: 24rpx; color: #888; }
.selected-drug { margin-top: 16rpx; padding: 16rpx; background: #E8F5E9; border-radius: 12rpx; }
.selected-label { font-size: 26rpx; color: #888; }
.selected-name { font-size: 28rpx; color: #2E8B57; font-weight: bold; }
.form-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.label { width: 160rpx; font-size: 28rpx; color: #555; }
.input { flex: 1; font-size: 28rpx; border: 2rpx solid #eee; border-radius: 8rpx; padding: 12rpx; }
.dosage-input { flex: 1; }
.unit-picker { margin-left: 12rpx; }
.unit-val { font-size: 28rpx; color: #2E8B57; font-weight: bold; background: #E8F5E9; border-radius: 8rpx; padding: 12rpx 20rpx; min-width: 80rpx; text-align: center; }
.picker-val { font-size: 28rpx; color: #333; padding: 8rpx 0; }
.check-btn { margin-top: 24rpx; background: #f0f0f0; color: #333; border-radius: 12rpx; font-size: 28rpx; }
.submit-btn { margin-top: 16rpx; background: linear-gradient(135deg, #FFB347 0%, #FFA726 100%); color: #5D4037; border-radius: 12rpx; font-size: 30rpx; box-shadow: 0 4rpx 12rpx rgba(255,179,71,0.3); }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal { background: #fff; border-radius: 20rpx; padding: 36rpx; width: 640rpx; max-height: 80vh; overflow-y: auto; }
.modal-title { font-size: 34rpx; font-weight: bold; display: block; margin-bottom: 24rpx; }
.allergy-warn { background: #fdf2f2; border-radius: 12rpx; padding: 20rpx; margin-bottom: 20rpx; }
.warn-title { font-size: 28rpx; font-weight: bold; color: #F44336; display: block; margin-bottom: 8rpx; }
.conflict-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.conflict-severity { font-size: 24rpx; font-weight: bold; padding: 4rpx 16rpx; border-radius: 20rpx; display: inline-block; margin-bottom: 8rpx; }
.severity-high { background: #fde8e8; color: #F44336; }
.severity-medium { background: #FFF3E0; color: #FF9800; }
.severity-low { background: #fefce8; color: #d4ac0d; }
.conflict-text { font-size: 28rpx; font-weight: bold; display: block; }
.conflict-warn { font-size: 26rpx; color: #555; display: block; margin-top: 8rpx; }
.conflict-advice { font-size: 24rpx; color: #4CAF50; display: block; margin-top: 4rpx; }
.no-conflict { font-size: 28rpx; color: #4CAF50; display: block; text-align: center; padding: 20rpx; }
.modal-close { margin-top: 24rpx; background: #2E8B57; color: #fff; border-radius: 12rpx; }
