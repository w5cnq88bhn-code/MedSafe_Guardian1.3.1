<view class="page">
  <view class="header-row">
    <text class="title">过敏药物管理</text>
    <button class="add-btn" bindtap="onToggleAdd">{{showAdd ? '取消' : '+ 添加'}}</button>
  </view>

  <view wx:if="{{showAdd}}" class="add-form">
    <input class="input" placeholder="过敏药物/成分名称（必填）" bindinput="onAllergenInput" value="{{newAllergen}}" />
    <input class="input" placeholder="过敏反应描述（选填）" bindinput="onReactionInput" value="{{newReaction}}" />
    <button class="confirm-btn" bindtap="onAddAllergy">确认添加</button>
  </view>

  <view wx:if="{{allergies.length === 0}}" class="empty">
    <text>暂无过敏记录</text>
  </view>

  <view wx:for="{{allergies}}" wx:key="id" class="allergy-item">
    <view class="allergy-info">
      <text class="allergy-name">{{item.drug_id_or_ingredient}}</text>
      <text class="allergy-reaction">{{item.reaction_type || '未知反应'}}</text>
      <text class="allergy-date">添加于 {{item.added_date}}</text>
    </view>
    <button class="del-btn" data-id="{{item.id}}" bindtap="onDelete">删除</button>
  </view>
</view>
