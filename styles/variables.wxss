/* 药安守护 全局色板 - 温暖医疗风格 */
page {
  /* 主题色 - 医疗绿 */
  --primary: #2E8B57;
  --primary-light: #3CB371;
  --primary-dark: #1E5F3C;
  --primary-bg: #E8F5E9;

  /* 按钮色 - 暖黄系 */
  --button-main: #FFB347;
  --button-hover: #FFA726;
  --button-press: #FF9800;
  --button-text: #5D4037;

  /* TabBar */
  --tabbar-bg: #F5F5F5;
  --tabbar-border: #E0E0E0;
  --tabbar-selected: #2E8B57;
  --tabbar-unselected: #999999;

  /* 背景 */
  --page-bg: #FFFFFF;
  --card-bg: #FAFAFA;
  --section-bg: #F0F7F0;

  /* 文字 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;

  /* 状态色 */
  --success: #4CAF50;
  --warning: #FF9800;
  --error: #F44336;
}
