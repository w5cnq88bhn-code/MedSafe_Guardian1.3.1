.page { padding: 24rpx; background: #FFFFFF; min-height: 100vh; }

/* 头部 */
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.header-title { font-size: 40rpx; font-weight: bold; color: #2E8B57; }
.add-btn { font-size: 26rpx; background: linear-gradient(135deg, #FFB347 0%, #FFA726 100%); color: #5D4037; border-radius: 32rpx; padding: 8rpx 28rpx; box-shadow: 0 4rpx 12rpx rgba(255,179,71,0.3); }
.loading, .empty { text-align: center; padding: 80rpx; color: #999; }

/* 时段分组 */
.group { margin-bottom: 32rpx; }
.group-header { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 16rpx; border-radius: 12rpx; margin-bottom: 16rpx; }
.section-title { display: flex; align-items: center; }

/* 时段标题背景 */
.group-header.morning { background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%); border-left: 6rpx solid #FFB347; }
.group-header.afternoon { background: linear-gradient(135deg, #FFFDE7 0%, #FFF9C4 100%); border-left: 6rpx solid #FFA726; }
.group-header.evening { background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%); border-left: 6rpx solid #2E8B57; }

/* 时段图标圆形背景 */
.slot-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.slot-morning  { background: linear-gradient(135deg, #FFB347 0%, #FFA726 100%); }
.slot-afternoon { background: linear-gradient(135deg, #FFA726 0%, #FF9800 100%); }
.slot-evening  { background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%); }
.slot-icon { font-size: 48rpx; line-height: 1; }
.slot-label { font-size: 30rpx; font-weight: bold; color: #333; }
.group-time { font-size: 26rpx; color: #888; }

/* 药品卡片 */
.drug-card { background: #FAFAFA; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; display: flex; align-items: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.drug-card.taken { opacity: 0.7; }
.drug-card.missed { border-left: 6rpx solid #F44336; }

/* 药品图标圆形背景 */
.drug-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.drug-icon { font-size: 44rpx; line-height: 1; }

/* 药品信息 */
.drug-info { flex: 1; }
.drug-name  { font-size: 32rpx; font-weight: bold; color: #222; display: block; }
.drug-brand { font-size: 24rpx; color: #888; display: block; margin-top: 4rpx; }
.drug-dose  { font-size: 26rpx; color: #555; display: block; margin-top: 4rpx; }

/* 按钮 */
.take-btn { font-size: 26rpx; border-radius: 32rpx; padding: 12rpx 28rpx; min-width: 160rpx; box-shadow: 0 4rpx 10rpx rgba(255,179,71,0.25); }
.take-btn.pending { background: linear-gradient(135deg, #FFB347 0%, #FFA726 100%); color: #5D4037; }
.take-btn.taken   { background: #4CAF50; color: #fff; box-shadow: 0 2rpx 6rpx rgba(76,175,80,0.3); }
.take-btn.missed  { background: #F44336; color: #fff; }

/* ── 饮食小贴士卡片 ─────────────────────────────────────────── */
.tips-card {
  margin-top: 8rpx;
  margin-bottom: 32rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
  overflow: hidden;
}

/* 卡片标题栏 */
.tips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #e8f8f0 0%, #d5f0e3 100%);
  border-bottom: 1rpx solid #c8e6d4;
}
.tips-title-row {
  display: flex;
  align-items: center;
}
.tips-icon { font-size: 40rpx; margin-right: 12rpx; }
.tips-title { font-size: 32rpx; font-weight: bold; color: #1a6b3a; margin-right: 12rpx; }
.tips-count {
  font-size: 22rpx;
  color: #fff;
  background: #2E8B57;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
}
.tips-toggle { font-size: 24rpx; color: #2E8B57; }

/* 单条贴士 */
.tip-item {
  border-left: 8rpx solid #ccc;
  margin: 20rpx 20rpx 0 20rpx;
  border-radius: 12rpx;
  padding: 20rpx 20rpx 16rpx 20rpx;
  margin-bottom: 0;
}
.tip-item:last-child { margin-bottom: 20rpx; }

/* 贴士头部 */
.tip-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.tip-drug-row { display: flex; align-items: center; flex: 1; }
.tip-severity-icon { font-size: 32rpx; margin-right: 10rpx; }
.tip-drug-name { font-size: 30rpx; font-weight: bold; color: #222; margin-right: 12rpx; }
.tip-badge {
  border-radius: 16rpx;
  padding: 4rpx 14rpx;
}
.tip-badge-text { font-size: 20rpx; color: #fff; }
.tip-expand-btn { font-size: 22rpx; color: #888; padding-left: 16rpx; }

/* 服药时机（始终显示） */
.tip-timing { margin-bottom: 8rpx; }
.tip-timing-row { display: flex; align-items: flex-start; margin-bottom: 6rpx; }
.tip-timing-dot { font-size: 26rpx; margin-right: 8rpx; flex-shrink: 0; }
.tip-timing-text { font-size: 26rpx; color: #444; line-height: 1.5; }

/* 展开详情区 */
.tip-section { margin-top: 14rpx; }
.tip-section-title { font-size: 24rpx; color: #666; display: block; margin-bottom: 10rpx; }

/* 食物标签 */
.tip-tags { display: flex; flex-wrap: wrap; gap: 10rpx; }
.tip-tag {
  font-size: 22rpx;
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
}
.tip-tag-avoid   { background: #fde8e8; color: #c0392b; }
.tip-tag-caution { background: #fef3e2; color: #d35400; }

/* 原因说明 */
.tip-reason {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 10rpx;
}
.tip-reason-text { font-size: 24rpx; color: #666; line-height: 1.6; }
