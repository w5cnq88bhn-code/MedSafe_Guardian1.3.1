.page { padding: 24rpx; background: #FFFFFF; min-height: 100vh; }
.tabs { display: flex; background: #FAFAFA; border-radius: 16rpx; padding: 8rpx; margin-bottom: 24rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #888; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; }
.tab.active { background: #2E8B57; color: #fff; font-weight: bold; box-shadow: 0 4rpx 12rpx rgba(46,139,87,0.3); }
.tab-icon { font-size: 32rpx; margin-bottom: 4rpx; }
.stat-card { background: linear-gradient(135deg, #FAFAFA 0%, #F5F5F5 100%); border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; border: 1rpx solid #E0E0E0; }
.drug-name { font-size: 30rpx; font-weight: bold; color: #222; display: block; margin-bottom: 12rpx; }
.stat-row { display: flex; justify-content: space-between; padding: 8rpx 0; }
.stat-label { font-size: 26rpx; color: #888; }
.stat-val { font-size: 26rpx; color: #333; }
.stat-val.red { color: #F44336; font-weight: bold; }
.stat-sub { font-size: 24rpx; color: #888; }
.summary-card { background: #FAFAFA; border-radius: 16rpx; padding: 40rpx; display: flex; justify-content: space-around; border: 1rpx solid #E0E0E0; }
.summary-item { text-align: center; }
.summary-num { font-size: 64rpx; font-weight: bold; color: #2E8B57; display: block; }
.summary-label { font-size: 26rpx; color: #888; }
.table-wrap { background: #fff; border-radius: 16rpx; overflow: hidden; }
.table-header { display: flex; background: #2E8B57; padding: 16rpx 12rpx; }
.table-header .col { color: #fff; font-size: 24rpx; font-weight: bold; }
.table-row { display: flex; padding: 16rpx 12rpx; border-bottom: 1rpx solid #f0f0f0; }
.col { font-size: 24rpx; }
.col.date { width: 160rpx; }
.col.name { flex: 1; }
.col.dose { width: 140rpx; }
.col.status { width: 80rpx; text-align: center; }
.col.status.taken { color: #4CAF50; }
.col.status.missed { color: #F44336; }

/* 28天统计 - 剂量异常卡片视觉强调 */
.stat-card.dose-abnormal { border-left: 6rpx solid #F44336; background: #fff8f8; }
.stat-card.dose-over { border-left: 6rpx solid #F44336; }
.stat-card.dose-under { border-left: 6rpx solid #FF9800; }
.dose-badge { display: inline-block; font-size: 22rpx; font-weight: bold; padding: 4rpx 16rpx; border-radius: 20rpx; margin-left: 12rpx; }
.dose-badge.over { background: #fde8e8; color: #F44336; }
.dose-badge.under { background: #FFF3E0; color: #FF8C42; border: 1rpx solid #FFCC80; }
.dose-badge.normal { background: #E8F5E9; color: #4CAF50; }
