.page { padding: 40rpx; background: #FFFFFF; min-height: 100vh; }
.profile-card { background: linear-gradient(135deg, #2E8B57 0%, #3CB371 100%); border-radius: 20rpx; padding: 40rpx; display: flex; align-items: center; margin-bottom: 32rpx; box-shadow: 0 4rpx 16rpx rgba(46,139,87,0.25); }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50rpx; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; margin-right: 24rpx; }
.avatar-icon { font-size: 56rpx; }
.profile-name { font-size: 36rpx; font-weight: bold; color: #fff; display: block; }
.profile-phone { font-size: 28rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 8rpx; }
.menu-list { background: #FAFAFA; border-radius: 16rpx; overflow: hidden; margin-bottom: 40rpx; border: 1rpx solid #E0E0E0; }
.menu-item { display: flex; align-items: center; padding: 32rpx; border-bottom: 1rpx solid #f5f5f5; }
.menu-icon { font-size: 40rpx; margin-right: 20rpx; }
.menu-label { flex: 1; font-size: 32rpx; color: #333; }
.menu-arrow { font-size: 36rpx; color: #ccc; }
.logout-btn { background: #fff; color: #F44336; border: 2rpx solid #F44336; border-radius: 16rpx; font-size: 32rpx; height: 88rpx; line-height: 88rpx; }
